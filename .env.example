# FoodHub Environment Configuration Template
# Copy this file to .env and update values for your environment

# ===== SERVICE PORTS =====
EUREKA_PORT=8761
CONFIG_PORT=8888
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
RESTAURANT_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
DELIVERY_SERVICE_PORT=8084
RECOMMENDATION_PORT=3000
FRONTEND_PORT=4200

# ===== MYSQL DATABASE CONFIGURATION =====
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=root

# User Service Database
MYSQL_DATABASE_USERS=foodhub_users
MYSQL_HOST_USERS=mysql-users
MYSQL_PORT_USERS=3306

# Restaurant Service Database
MYSQL_DATABASE_RESTAURANTS=foodhub_restaurants
MYSQL_HOST_RESTAURANTS=mysql-restaurants
MYSQL_PORT_RESTAURANTS=3307

# Order Service Database
MYSQL_DATABASE_ORDERS=foodhub_orders
MYSQL_HOST_ORDERS=mysql-orders
MYSQL_PORT_ORDERS=3308

# Delivery Service Database
MYSQL_DATABASE_DELIVERY=foodhub_delivery
MYSQL_HOST_DELIVERY=mysql-delivery
MYSQL_PORT_DELIVERY=3309

# ===== MONGODB CONFIGURATION =====
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=foodhub_recommendations
MONGODB_CONNECTION_STRING=mongodb://mongodb:27017/foodhub_recommendations

# ===== RABBITMQ CONFIGURATION =====
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ===== KEYCLOAK CONFIGURATION =====
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8180
KEYCLOAK_URL=http://keycloak:8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_REALM=foodhub
KEYCLOAK_CLIENT_ID=foodhub-frontend
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# ===== MONITORING CONFIGURATION =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN=admin
GRAFANA_PASSWORD=admin

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== DOCKER REGISTRY (for CI/CD) =====
DOCKER_REGISTRY_USERNAME=your-dockerhub-username
DOCKER_REGISTRY_TOKEN=your-dockerhub-token
DOCKER_REGISTRY_URL=docker.io

# ===== JWT CONFIGURATION =====
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# ===== CORS CONFIGURATION =====
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type

# ===== FEATURE FLAGS =====
ENABLE_ANALYTICS=true
ENABLE_RECOMMENDATIONS=true
ENABLE_MONITORING=true

# ===== ENVIRONMENT =====
environment=development
# Options: development, staging, production

